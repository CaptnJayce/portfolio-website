{
  "name": "portfolio_website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev --port 3000",
    "lint": "eslint src --ignore-pattern .react-router",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit",
    "check": "react-router typegen && tsc --noEmit",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase reset"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.0.0",
    "@fortawesome/free-brands-svg-icons": "^7.0.0",
    "@fortawesome/react-fontawesome": "^0.2.3",
    "@netlify/vite-plugin": "^2.11.5",
    "@netlify/vite-plugin-react-router": "^3.1.1",
    "@react-router/node": "^7.1.1",
    "@react-router/serve": "^7.1.1",
    "@supabase/supabase-js": "^2.47.10",
    "isbot": "^5.1.17",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@react-router/dev": "^7.1.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.23.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "supabase": "^2.10.3",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.27.0",
    "vite": "^6.0.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
